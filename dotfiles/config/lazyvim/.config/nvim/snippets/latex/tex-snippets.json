{
  "BeginFrame": {
    "prefix": "beg",
    "body": ["\\begin{$1}", "\t$0", "\\end{$1}"],
    "description": "Begin End Frame"
  },
  "TableEnv": {
    "prefix": "table",
    "body": [
      "\\begin{table}[${1:htpb}]",
      "\t\\centering",
      "\t\\caption{${2:caption}}",
      "\t\\label{tab:${3:label}}",
      "\t\\begin{tabular}{${5:c}}",
      "\t$0${5/((?<=.)c|l|r)|./(?1: & )/g}",
      "\t\\end{tabular}",
      "\\end{table}"
    ],
    "description": "Table Environment"
  },
  "Frame": {
    "prefix": "frame",
    "body": ["\\begin{frame}", "\t\\frametitle{$1}", "\\end{frame}", "$0"],
    "description": "Add a beamer frame"
  }
}
