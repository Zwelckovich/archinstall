{
  "Minipage": {
    "prefix": "minipage",
    "body": ["\\begin{minipage}[t]{$0\\textwidth}", "\\end{minipage}%"],
    "description": "Add a table"
  },
  "BeginFrame": {
    "prefix": "beg",
    "body": ["\\begin{$1}", "\t$0", "\\end{$1}"],
    "description": "Begin End Frame"
  },
  "Frame": {
    "prefix": "frame",
    "body": ["\\begin{frame}", "\t\\frametitle{$1}", "\\end{frame}", "$0"],
    "description": "Add a beamer frame"
  }
}
