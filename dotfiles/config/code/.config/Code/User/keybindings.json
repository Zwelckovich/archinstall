// Place your key bindings in this file to override the defaultsauto[]
[
	{
		"key": "ctrl+[Backslash]",
		"command": "editor.action.commentLine",
		"when": "editorTextFocus && !editorReadonly"
	},
	{
		"key": "ctrl+[Semicolon]",
		"command": "workbench.action.terminal.toggleTerminal",
		"when": "terminal.active"
	},
	{
		"key": "ctrl+[Quote]",
		"command": "slidev-preview.focus"
	},
	{
		"key": "ctrl+[BracketLeft]",
		"command": "settings.cycle",
		"args": {
			"id": "toggleTyInlayHints",
			"overrideWorkspaceSettings": true,
			"values": [
				{
					"ty.inlayHints.callArgumentNames": true,
					"ty.inlayHints.variableTypes": true
				},
				{
					"ty.inlayHints.callArgumentNames": false,
					"ty.inlayHints.variableTypes": false
				}
			]
		}
	}
]
